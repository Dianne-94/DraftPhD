label "fireTruck1_state_Idle" = (fireTruck1_state=0);
label "fireTruck1_state_Navigating" = (fireTruck1_state=1);
label "fireTruck1_state_Extinguishing" = (fireTruck1_state=2);

label "fireTruck2_state_Idle" = (fireTruck2_state=0);
label "fireTruck2_state_Navigating" = (fireTruck2_state=1);
label "fireTruck2_state_Extinguishing" = (fireTruck2_state=2);

label "fireTruck3_state_Idle" = (fireTruck3_state=0);
label "fireTruck3_state_Navigating" = (fireTruck3_state=1);
label "fireTruck3_state_Extinguishing" = (fireTruck3_state=2);

label "fireTruck4_state_Idle" = (fireTruck4_state=0);
label "fireTruck4_state_Navigating" = (fireTruck4_state=1);
