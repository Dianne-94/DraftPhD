label "fireTruck5_state_Extinguishing" = (fireTruck5_state=2);

label "fireTruck6_state_Idle" = (fireTruck6_state=0);
label "fireTruck6_state_Navigating" = (fireTruck6_state=1);
label "fireTruck6_state_Extinguishing" = (fireTruck6_state=2);

label "allAvailableModules_reachIdle" = (fireTruck1_state=0 & fireTruck2_state=0 & fireTruck3_state=0 & fireTruck4_state=0 & fireTruck5_state=0 & fireTruck6_state=0);
label "allModules_reachIdle" = (fireTruck1_state=0 & fireTruck2_state=0 & fireTruck3_state=0 & fireTruck4_state=0 & fireTruck5_state=0 & fireTruck6_state=0);
label "allAvailableModules_reachNavigating" = (fireTruck1_state=1 & fireTruck2_state=1 & fireTruck3_state=1 & fireTruck4_state=1 & fireTruck5_state=1 & fireTruck6_state=1);
label "allModules_reachNavigating" = (fireTruck1_state=1 & fireTruck2_state=1 & fireTruck3_state=1 & fireTruck4_state=1 & fireTruck5_state=1 & fireTruck6_state=1);
label "allAvailableModules_reachExtinguishing" = (fireTruck1_state=2 & fireTruck2_state=2 & fireTruck3_state=2 & fireTruck4_state=2 & fireTruck5_state=2 & fireTruck6_state=2);
label "allModules_reachExtinguishing" = (fireTruck1_state=2 & fireTruck2_state=2 & fireTruck3_state=2 & fireTruck4_state=2 & fireTruck5_state=2 & fireTruck6_state=2);

