ctmc

// Grid from XMI
const int X_MAX = 10;
const int Y_MAX = 10;

// Constants extracted from guardExpression
const int FIRE_INTENSITY = 3;
const int WATER_LEVEL = 3;
const int NUMBER_OF_AGENTS = 6;
const bool WITHIN_GRID = true;
const int AGENT_DISTANCE = 1;

// Formula reconstructed from guardExpression (uses constants declared above)
formula COND_ALL = (FIRE_INTENSITY=3) & (WATER_LEVEL=3) & (NUMBER_OF_AGENTS=6) & (WITHIN_GRID=true) & (AGENT_DISTANCE=1);

global water_level : [0..WATER_LEVEL] init 0;
global distance_level : [0..AGENT_DISTANCE] init AGENT_DISTANCE;

label "water_level_empty" = (water_level=0);
label "water_level_low"   = (water_level <= 1);
label "distance_level_empty" = (distance_level=0);
label "distance_level_low"   = (distance_level <= 1);

module fireTruck1
    // States: 0=Idle, 1=Navigating, 2=Extinguishing
    fireTruck1_state : [0..2] init 0;

    // Transitions parsed from XMI
    [fireTruck1_Idle_to_Navigating] fireTruck1_state=0 & COND_ALL -> 1.20 : (fireTruck1_state'=1);
    [fireTruck1_Navigating_to_Extinguishing] fireTruck1_state=1 & COND_ALL -> 1.00 : (fireTruck1_state'=2);
    [fireTruck1_Extinguishing_to_Idle] fireTruck1_state=2 & COND_ALL -> 1.10 : (fireTruck1_state'=0);

endmodule

