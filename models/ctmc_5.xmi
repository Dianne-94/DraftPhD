<xmi:XMI xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:ctmc="http://example/ctmc">
  <ctmc:CTMC name="FireRescue_Easy" utility="0.95" guardExpression="(verificationHorizon = 10) AND (timeUnit = &quot;seconds&quot;) AND (fireSpreadInterval = 3) AND (ensembleFormation = 0.9) AND (brigadesMin = 6) AND (initialWaterTank = 3) AND (fireIntensity = 1) AND (travelSuccess = 1.0) AND (extinguishSuccess = 0.9) AND (trafficCongestion = &quot;none&quot;) AND (gridWidth = 10) AND (gridHeight = 10)"/>
