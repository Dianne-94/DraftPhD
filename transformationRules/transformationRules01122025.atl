-- @path MM=/PHDMadinahNewUpdates/metamodels/ctmc.ecore
-- @path tcoel=/PHDMadinahNewUpdates/metamodels/tcoel.ecore
-- @atlcompiler emftvm

module transformationRules01122025;
create OUT : ctmc from IN : tcoel;

-- =========================
-- Rule 1 Top-level: Ensemble → CTMC
-- =========================
rule Ensemble2CTMC {
    from ens : tcoel!Ensemble
    to   c   : ctmc!CTMC (
            name            <- ens.name,
            utility         <- ens.utility,        -- keep your utility mapping
            guardExpression <- ens.getConditionText(),
            states          <- ens.component->collect(c | c.role.state)->flatten()->asOrderedSet(),
            transition      <- ens.component->collect(c | c.role.transition)->flatten()->asOrderedSet()
    )
}

-- Optional: Component → CTMC (if you also materialize per-component CTMCs)
rule Component2CTMC {
    from comp : tcoel!Component
    to   c    : ctmc!CTMC (
            name       <- comp.name,
            states     <- comp.role.state->asOrderedSet(),
            transition <- comp.role.transition->asOrderedSet()
    )
}

-- =========================
-- Rule 2 States
-- =========================
rule State2State {
    from s : tcoel!State
    to   t : ctmc!State (
        id   <- if not s.id.oclIsUndefined() and s.id <> '' then s.id
                else if not s.name.oclIsUndefined() and s.name <> '' then s.name
                else 'default_id' endif endif,
        name <- if not s.name.oclIsUndefined() and s.name <> '' then s.name else 'unnamed' endif
    )
}

-- =========================
-- Rule 3 Transitions (labels, rate, guards, state resolution)
-- =========================
rule Transition2CTMCTransition {
    from trans : tcoel!Transition
    to   t     : ctmc!Transition (
        -- Prefer an explicit label; fall back to name; else derive by pattern
        name            <- thisModule.resolveTransitionName(trans),
        initial         <- thisModule.getStateByAny(trans.initial, trans, true),
        target          <- thisModule.getStateByAny(trans.target,  trans, false),
        rate            <- trans.dynRate(),
        guardExpression <- thisModule.andText(trans.guardText(), thisModule.attrGuard(thisModule.ownerComponent(trans))),
        utility         <- thisModule.findUtilityForTransition(trans)
    )
}

